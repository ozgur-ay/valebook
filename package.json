{
  "name": "valebook",
  "version": "1.1.2",
  "description": "Vale Cafe Parking Cash Register Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon server.js",
    "build": "electron-builder -w",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "valet",
    "parking",
    "cashier",
    "ledger"
  ],
  "author": "Antigravity",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "electron": "^30.1.0",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0"
  },
  "build": {
    "appId": "com.valebook.app",
    "productName": "ValeBook",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ozgur-ay",
        "repo": "valebook",
        "releaseType": "release"
      }
    ]
  }
}
